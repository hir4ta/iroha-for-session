{
  "name": "iroha-for-session",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Persist Claude Code sessions to Notion as a living project memory.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:recall": "bun tests/recall-eval.ts",
    "test:scale": "bun tests/recall-scale.ts",
    "test:rerank": "bun tests/rerank-eval.ts",
    "test:hybrid": "bun tests/hybrid-eval.ts",
    "rerank:setup": "bun scripts/rerank-setup.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "1.3.14",
    "typescript": "6.0.3"
  }
}
