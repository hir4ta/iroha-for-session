{
  "name": "iroha-for-session",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Persist Claude Code sessions to Notion as a living project memory.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test:bash": "bash tests/selftest.sh",
    "test:recall": "bash tests/recall-eval.sh",
    "test:scale": "bash tests/recall-scale.sh",
    "test:rerank": "bash tests/rerank-eval.sh",
    "test:hybrid": "bash tests/hybrid-eval.sh",
    "test": "bash tests/selftest.sh && bash tests/recall-eval.sh && bash tests/recall-scale.sh && bash tests/rerank-eval.sh && bash tests/hybrid-eval.sh",
    "rerank:setup": "bash scripts/rerank-setup.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "1.3.14",
    "typescript": "6.0.3"
  }
}
