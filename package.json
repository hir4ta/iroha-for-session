{
  "name": "iroha-for-session",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "description": "Persist Claude Code sessions to Notion as a living project memory.",
  "engines": {
    "bun": ">=1.1"
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:recall": "bun tests/recall-eval.ts",
    "test:scale": "bun tests/recall-scale.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bun": "1.3.14",
    "fast-check": "4.8.0",
    "typescript": "6.0.3"
  }
}
