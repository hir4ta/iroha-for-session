{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "iroha-for-notion: inject the project's prior State and a save reminder at session start.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
