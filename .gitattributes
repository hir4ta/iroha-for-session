# Normalize line endings to LF in the repo (a world-distributed plugin is cloned
# on Windows too; the .ts hooks/skills and shell fixtures must stay LF).
* text=auto eol=lf

*.ts   text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.toml text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
bun.lock text eol=lf
